/* pages/order/order.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.header {
  padding: 40rpx;
  background-color: #fff;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.content {
  flex: 1;
  overflow: auto;
  padding-bottom: 120rpx;
}

.product-list {
  padding: 20rpx;
}

.product-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
}

.product-info {
  display: flex;
  flex-direction: column;
  text-align: left;
}

.product-name {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.product-price {
  font-size: 28rpx;
  color: #1890ff;
}

.product-action {
  display: flex;
  align-items: center;
}

.product-counter {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.product-minus {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
}

.product-count {
  font-size: 32rpx;
  color: #333;
  min-width: 50rpx;
  text-align: center;
}

.add-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #1890ff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
}

.add-btn:active {
  background-color: #096dd9;
}

.add-icon {
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
  line-height: 1;
}

.count-text {
  font-size: 32rpx;
  color: #333;
  margin-left: 20rpx;
  min-width: 40rpx;
  text-align: center;
}

.empty {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}

/* 购物车底部栏 */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 150rpx;
  background-color: #333;
  display: flex;
  align-items: center;
  padding-left: 20rpx;
}

.cart-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #1890ff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.cart-icon {
  font-size: 40rpx;
}

.cart-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.total-label {
  font-size: 28rpx;
  color: #fff;
}

.total-price {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.settle-btn {
  width: 200rpx;
  height: 150rpx;
  background-color: #1890ff;
  color: #fff;
  font-size: 32rpx;
  border: none;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 购物车半窗 */
.cart-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 150rpx;
  background-color: rgba(0, 0, 0, 0.5);
}

.cart-drawer {
  position: fixed;
  bottom: 150rpx;
  left: 0;
  right: 0;
  height: 600rpx;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
}

.drawer-header {
  flex-shrink: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.drawer-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.drawer-close {
  font-size: 48rpx;
  color: #999;
}

.drawer-content {
  flex: 1;
  height: 500rpx;
  padding: 20rpx 50rpx 20rpx 20rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.cart-empty {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
}

.cart-empty-text {
  font-size: 28rpx;
  color: #999;
}

.cart-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 40rpx 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.cart-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.cart-item-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.cart-item-price {
  font-size: 26rpx;
  color: #1890ff;
}

.cart-item-action {
  display: flex;
  align-items: center;
}

.cart-minus,
.cart-add {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
}

.cart-count {
  font-size: 30rpx;
  color: #333;
  min-width: 60rpx;
  text-align: center;
}
